# 이 파일을 복사해서 .env로 이름을 바꾼 뒤 실제 값을 채워주세요.
# .env는 Git에 올라가지 않으니 본인의 비밀 값을 안전하게 보관할 수 있습니다.

# Google OAuth Client ID (Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Upstage Solar LLM API Key (https://console.upstage.ai 에서 발급)
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxx

# Flask 서버 포트
PORT=5000
